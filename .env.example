# =========================
# DATABASE
# =========================
# PostgreSQL (Neon / Supabase / Railway / local)
DATABASE_URL="postgresql://user:password@localhost:5432/valmora?schema=public"

# =========================
# NEXTAUTH
# =========================
NEXTAUTH_URL="http://localhost:3000"
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =========================
# APP
# =========================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Valmora"
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_CURRENCY_SYMBOL="$"

# =========================
# STRIPE
# =========================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =========================
# CLOUDINARY (image uploads)
# =========================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# =========================
# EMAIL (SMTP — e.g. Resend, SendGrid, Gmail)
# =========================
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Valmora <no-reply@valmora.com>"

# =========================
# ADMIN SEED CREDENTIALS
# =========================
SEED_ADMIN_EMAIL="admin@valmora.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
