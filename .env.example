# =========================
# DATABASE
# =========================
# PostgreSQL (Neon / Supabase / Railway / local)
DATABASE_URL="postgresql://user:password@localhost:5432/Vailmora?schema=public"

# =========================
# NEXTAUTH
# =========================
NEXTAUTH_URL="http://localhost:3000"
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# =========================
# APP
# =========================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Vailmora"
NEXT_PUBLIC_CURRENCY="PKR"
NEXT_PUBLIC_CURRENCY_SYMBOL="Rs"

# =========================
# STRIPE
# =========================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =========================
# CLOUDINARY (image uploads)
# =========================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# =========================
# EMAIL (Resend)
# =========================
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
# Use onboarding@resend.dev for testing; use your verified domain in production
EMAIL_FROM="Vailmora <onboarding@resend.dev>"

# =========================
# ADMIN SEED CREDENTIALS
# =========================
SEED_ADMIN_EMAIL="admin@Vailmora.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
